def download_file(url: str, dest: str, desc: str = "") -> bool:
    """Download *url* → *dest*.  Returns True on success."""
    os.makedirs(os.path.dirname(dest), exist_ok=True)
    if os.path.isfile(dest):
        print(f"  [{desc}] already exists: {dest}")
        return True
    print(f"  [{desc}] downloading → {dest}  …", end=" ", flush=True)
    try:
        urllib.request.urlretrieve(url, dest)
        print("done.")
        return True
    except Exception as e:
        print(f"FAILED ({e})")
        if os.path.isfile(dest):
            os.remove(dest)
        return False


def ensure_pose_model():
    """Download RTMPose-S config & checkpoint if missing.

    Uses mim (installed with openmim) for reliable model downloading.
    """
    # We need to be able to reassign POSE_CHECKPOINT in case mim uses
    # a different filename than our hardcoded default.
    global POSE_CHECKPOINT

    need_cfg = not os.path.isfile(POSE_CONFIG)
    need_ckpt = not os.path.isfile(POSE_CHECKPOINT)

    if not need_cfg and not need_ckpt:
        print("[INFO] RTMPose-S model files already present.")
        return

    # ── Try mim download (handles URLs / filenames correctly) ──────
    import subprocess
    print("[INFO] Downloading RTMPose-S model via mim ...")
    result = subprocess.run(
        ["mim", "download", "mmpose",
         "--config", "rtmpose-s_8xb256-420e_coco-256x192",
         "--dest", HERE],
        capture_output=True, text=True
    )
    if result.returncode == 0:
        print("[INFO] mim download succeeded.")
        # mim may name the checkpoint differently; find the actual .pth
        for f in os.listdir(HERE):
            if f.startswith("rtmpose-s_simcc") and f.endswith(".pth"):
                actual = os.path.join(HERE, f)
                if actual != POSE_CHECKPOINT:
                    print(f"[INFO] Using checkpoint: {f}")
                    POSE_CHECKPOINT = actual
                break
    else:
        print(f"[WARN] mim download failed:\n{result.stderr}")
        # ── Fallback: direct URL download ──────────────────────────
        config_url = (
            "https://raw.githubusercontent.com/open-mmlab/mmpose/main/"
            "configs/body_2d_keypoint/rtmpose/coco/"
            "rtmpose-s_8xb256-420e_coco-256x192.py"
        )
        ckpt_url = (
            "https://download.openmmlab.com/mmpose/v1/projects/rtmpose/"
            "rtmpose-s_simcc-coco_pt-aic-coco_420e-256x192-8edcf0d7_20230127.pth"
        )
        ok_cfg = download_file(config_url, POSE_CONFIG, "pose config")
        ok_ckpt = download_file(ckpt_url, POSE_CHECKPOINT, "pose checkpoint")

        if not ok_cfg or not ok_ckpt:
            print("\n[ERROR] Could not download RTMPose model automatically.")
            print(f"  Manual:  mim download mmpose --config "
                  f"rtmpose-s_8xb256-420e_coco-256x192 --dest {HERE}")
            sys.exit(1)


def angle_from_vertical(dx: float, dy: float) -> float:
    """Angle (degrees) between vector (dx,dy) and the upward vertical (0,-1).

    In image coords Y grows downward, so vertical-up is (0, -1).
    Returns 0° = perfectly upright, 90° = horizontal, 180° = upside-down.
    """
    length = np.hypot(dx, dy)
    if length < 1e-6:
        return 0.0
    cos_ang = -dy / length          # dot((dx,dy), (0,-1))
    cos_ang = np.clip(cos_ang, -1.0, 1.0)
    return float(np.degrees(np.arccos(cos_ang)))


def midpoint(p1, p2):
    """Return (x, y) midpoint of two 2D points."""
    return ((p1[0] + p2[0]) / 2.0, (p1[1] + p2[1]) / 2.0)


def log_event(message: str):
    """Append a timestamped line to LOG_FILE and print it."""
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] {message}"
    print(line)
    os.makedirs(os.path.dirname(LOG_FILE), exist_ok=True)
    with open(LOG_FILE, "a") as f:
        f.write(line + "\n")
        f.flush()


