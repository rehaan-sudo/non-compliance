#  Drawing helpers
# ═══════════════════════════════════════════════════════════════════════════

def draw_skeleton(frame, keypoints, scores, color=(0, 255, 255), thickness=2):
    """Draw COCO-17 skeleton on *frame* (mutated in-place)."""
    if keypoints is None:
        return
    kp = keypoints
    sc = scores
    h, w = frame.shape[:2]

    # Draw edges
    for (i, j) in SKELETON_EDGES:
        if sc[i] < POSE_MIN_KEYPOINT_CONF or sc[j] < POSE_MIN_KEYPOINT_CONF:
            continue
        pt1 = (int(kp[i][0]), int(kp[i][1]))
        pt2 = (int(kp[j][0]), int(kp[j][1]))
        if 0 <= pt1[0] < w and 0 <= pt1[1] < h and 0 <= pt2[0] < w and 0 <= pt2[1] < h:
            cv2.line(frame, pt1, pt2, color, thickness)

    # Draw keypoints
    for i in range(len(kp)):
        if sc[i] < POSE_MIN_KEYPOINT_CONF:
            continue
        x, y = int(kp[i][0]), int(kp[i][1])
        if 0 <= x < w and 0 <= y < h:
            cv2.circle(frame, (x, y), 3, color, -1)


def draw_overlay(frame, tp: TrackedPerson):
    """Draw bbox, state label, stillness counter, and skeleton on frame."""
    x1, y1, x2, y2 = tp.bbox
    color = STATE_COLORS.get(tp.state, (255, 255, 255))

    # Bounding box
    cv2.rectangle(frame, (x1, y1), (x2, y2), color, 2)

    # State label above bbox
    label = f"ID:{tp.person_id} [{tp.state}]"
    cv2.putText(frame, label, (x1, max(y1 - 10, 15)),
                cv2.FONT_HERSHEY_SIMPLEX, 0.5, color, 2)

    # Stillness counter below state label
    if tp.state in (STATE_STILL_CANDIDATE, STATE_POSTURE_CONFIRMED):
        dur_text = f"still:{tp.stillness_duration:.0f}s"
        cv2.putText(frame, dur_text, (x1, max(y1 - 28, 15)),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.45, (0, 200, 255), 1)

    # Posture angles (if available)
    if tp.head_angle > 0 or tp.torso_angle > 0:
        angle_text = f"H:{tp.head_angle:.0f}° T:{tp.torso_angle:.0f}°"
        cv2.putText(frame, angle_text, (x1, y2 + 15),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.4, (200, 200, 200), 1)

    # Skeleton — only draw when actively monitoring posture
    if tp.state in (STATE_STILL_CANDIDATE, STATE_POSTURE_CONFIRMED):
        draw_skeleton(frame, tp.keypoints, np.ones(17), color=color)


