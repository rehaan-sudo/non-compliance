def run_pose_on_persons(pose_model, frame, bboxes_xyxy):

    if not bboxes_xyxy:
        return []

    # inference_topdown expects list of [[x1,y1,x2,y2], ...]
    bbox_list = [[float(v) for v in b] for b in bboxes_xyxy]

    try:
        results = inference_topdown(pose_model, frame, bboxes=bbox_list)
    except Exception as e:
        print(f"  [WARN] pose inference failed: {e}")
        return [(None, None)] * len(bboxes_xyxy)

    out = []
    for r in results:
        try:
            kps = r.pred_instances.keypoints  # shape (N, 17, 2)
            scores = r.pred_instances.keypoint_scores  # shape (N, 17)
            if kps is not None and len(kps) > 0:
                out.append((kps[0].cpu().numpy(), scores[0].cpu().numpy()))
            else:
                out.append((None, None))
        except Exception:
            out.append((None, None))
    return out


def compute_posture_angles(keypoints, scores):

    if keypoints is None or scores is None:
        return None, None

    kp = keypoints  # (17, 2)
    sc = scores     # (17,)

    # Required keypoints and their minimum confidence
    required = {
        "nose": KP["nose"],
        "left_shoulder": KP["left_shoulder"],
        "right_shoulder": KP["right_shoulder"],
        "left_hip": KP["left_hip"],
        "right_hip": KP["right_hip"],
    }
    for name, idx in required.items():
        if sc[idx] < POSE_MIN_KEYPOINT_CONF:
            return None, None

    # Neck ≈ midpoint of left & right shoulders
    neck = midpoint(kp[KP["left_shoulder"]], kp[KP["right_shoulder"]])
    # Hip centre ≈ midpoint of left & right hips
    hip_centre = midpoint(kp[KP["left_hip"]], kp[KP["right_hip"]])
    # Nose
    nose = kp[KP["nose"]]

    # Head vector: neck → nose
    head_dx = nose[0] - neck[0]
    head_dy = nose[1] - neck[1]
    head_angle = angle_from_vertical(head_dx, head_dy)

    # Torso vector: neck → hip_centre
    torso_dx = hip_centre[0] - neck[0]
    torso_dy = hip_centre[1] - neck[1]
    torso_angle = angle_from_vertical(torso_dx, torso_dy)

    return head_angle, torso_angle


# ═══════════════════════════════════════════════════════════════════════════
#  State-machine transitions
# ═══════════════════════════════════════════════════════════════════════════

def update_state(tp: TrackedPerson, fps: float):

    pid = tp.person_id

    # ── COOLDOWN ──────────────────────────────────────────────────────
    if tp.state == STATE_COOLDOWN:
        tp.cooldown_remaining -= 1.0 / fps
        if tp.cooldown_remaining <= 0:
            tp.state = STATE_NORMAL
            tp.cooldown_remaining = 0.0
            tp.stillness_duration = 0.0
            tp.posture_bad_frames = 0
            print(f"  [STATE] person_id={pid}: COOLDOWN → NORMAL")
        return  # cooldown blocks all other transitions

    # ── NORMAL → STILL_CANDIDATE ──────────────────────────────────────
    if tp.state == STATE_NORMAL:
        if tp.stillness_duration >= STILLNESS_THRESHOLD_SEC:
            tp.state = STATE_STILL_CANDIDATE
            tp.posture_bad_frames = 0
            print(f"  [STATE] person_id={pid}: NORMAL → STILL_CANDIDATE "
                  f"(stillness={tp.stillness_duration:.1f}s)")
        return

    # ── STILL_CANDIDATE → NORMAL (moved before posture confirmed) ────
    if tp.state == STATE_STILL_CANDIDATE:
        if tp.stillness_duration <= 0:  # was reset because movement detected
            tp.state = STATE_NORMAL
            tp.posture_bad_frames = 0
            print(f"  [STATE] person_id={pid}: STILL_CANDIDATE → NORMAL (moved)")
            return

        # Check posture
        posture_bad = (
            tp.head_angle > HEAD_DOWN_ANGLE_THRESHOLD or
            tp.torso_angle > LYING_ANGLE_THRESHOLD
        )

        if posture_bad and tp.head_angle > 0:  # valid keypoints available
            tp.posture_bad_frames += 1
        else:
            tp.posture_bad_frames = max(0, tp.posture_bad_frames - 1)

        posture_bad_sec = tp.posture_bad_frames / fps
        if posture_bad_sec >= POSTURE_CONFIRM_SEC:
            # ── CONFIRMED ──────────────────────────────────────────
            alert_msg = (
                f"ALERT: possible sleeping worker detected "
                f"(person_id={pid}, stillness={tp.stillness_duration:.1f}s, "
                f"head_angle={tp.head_angle:.1f}°, "
                f"torso_angle={tp.torso_angle:.1f}°)"
            )
            print(f"\n{'='*70}\n{alert_msg}\n{'='*70}\n")
            log_event(alert_msg)

            tp.state = STATE_POSTURE_CONFIRMED
            # Immediately trigger cooldown
            tp.state = STATE_COOLDOWN
            tp.cooldown_remaining = COOLDOWN_SECONDS
            print(f"  [STATE] person_id={pid}: POSTURE_CONFIRMED → COOLDOWN "
                  f"({COOLDOWN_SECONDS}s)")
        return


