#  Main processing loop
# ═══════════════════════════════════════════════════════════════════════════

def main():
    ensure_dirs()

    # ── Sanity-checks ──────────────────────────────────────────────────
    for path, desc in [
        (DETECTOR_CONFIG, "RTMDet config"),
        (DETECTOR_CHECKPOINT, "RTMDet checkpoint"),
    ]:
        if not os.path.isfile(path):
            sys.exit(f"[ERROR] {desc} not found: {path}")

    if not os.path.isfile(VIDEO_PATH):
        sys.exit(
            f"[ERROR] Test video not found: {VIDEO_PATH}\n"
            f"  Please place a test video at that path, or edit VIDEO_PATH "
            f"at the top of this script."
        )

    # ── Ensure RTMPose model is downloaded ─────────────────────────────
    ensure_pose_model()

    if DEVICE.startswith("cuda") and not torch.cuda.is_available():
        print("[WARN] CUDA not available — falling back to CPU.")
        device = "cpu"
    else:
        device = DEVICE

    # ── Load models ────────────────────────────────────────────────────
    print(f"[INFO] Loading RTMDet-Tiny person detector on {device} ...")
    detector = init_detector(DETECTOR_CONFIG, DETECTOR_CHECKPOINT, device=device)
    print("[INFO] RTMDet-Tiny loaded.")

    # ── Load RTMPose (must switch scope temporarily) ───────────────────
    print(f"[INFO] Loading RTMPose-S pose estimator on {device} ...")
    DefaultScope.get_instance("pose_scope", scope_name="mmpose")
    register_all_modules()
    pose_model = init_pose_model(POSE_CONFIG, POSE_CHECKPOINT, device=device)
    print("[INFO] RTMPose-S loaded.")

    # ── Open video ─────────────────────────────────────────────────────
    print(f"[INFO] Opening video: {VIDEO_PATH}")
    cap = cv2.VideoCapture(VIDEO_PATH)
    if not cap.isOpened():
        sys.exit(f"[ERROR] Cannot open video: {VIDEO_PATH}")

    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    fps_video = cap.get(cv2.CAP_PROP_FPS)
    width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    if fps_video <= 0:
        fps_video = 25.0  # fallback
        print(f"[WARN] Could not read FPS from video, assuming {fps_video}")

    print(f"[INFO] {width}x{height}, {total_frames} frames, {fps_video:.1f} FPS")

    # ── Dynamic MAX_MISSING_FRAMES based on FPS (≈8 seconds) ──────────
    MAX_MISSING_FRAMES = int(fps_video * 8)
    print(f"[INFO] MAX_MISSING_FRAMES={MAX_MISSING_FRAMES} "
          f"(≈{MAX_MISSING_FRAMES/fps_video:.1f}s of missed detections)")

    # ── Output video writer ────────────────────────────────────────────
    fourcc = cv2.VideoWriter_fourcc(*"mp4v")
    out_writer = cv2.VideoWriter(OUTPUT_VIDEO, fourcc, fps_video, (width, height))
    if not out_writer.isOpened():
        sys.exit(f"[ERROR] Cannot create output video: {OUTPUT_VIDEO}")
    print(f"[INFO] Writing annotated output → {OUTPUT_VIDEO}")

    if SHOW_DISPLAY:
        cv2.namedWindow("Sleep Detection", cv2.WINDOW_NORMAL)

    # ── Tracker state ──────────────────────────────────────────────────
    tracked: dict[int, TrackedPerson] = {}  # person_id → TrackedPerson

    # Recently-lost tracks buffer (for re-acquisition within short time window)
    # Structure: {person_id: (last_centroid, stillness_duration, anchor_centroid,
    #                         anchor_set_time, movement_reset_counter, lost_time_sec,
    #                         state, posture_bad_frames)}
    recently_lost_tracks: dict[int, tuple] = {}

    # Stillness milestone tracking for debug output
    _stillness_milestones: dict[int, set] = {}  # person_id → set of % milestones reached

    frame_idx = 0
    tick_start = time.time()

    # ── FRAME LOOP ─────────────────────────────────────────────────────
    while True:
        ret, frame = cap.read()
        if not ret:
            break
        frame_idx += 1
        frame_ts = frame_idx / fps_video  # approximate timestamp from frame count

        # ── 1. Person detection ────────────────────────────────────
        with DefaultScope.overwrite_default_scope("mmdet"):
            det_result = inference_detector(detector, frame)
        preds = det_result.pred_instances
        bboxes_tensor = preds.bboxes
        scores_tensor = preds.scores
        labels_tensor = preds.labels

        # Filter: only "person" class, above confidence threshold
        person_bboxes = []
        for bbox, score, label in zip(bboxes_tensor, scores_tensor, labels_tensor):
            if int(label) == PERSON_CLASS_ID and float(score) >= CONF_THRESHOLD:
                x1, y1, x2, y2 = map(int, bbox)
                person_bboxes.append([x1, y1, x2, y2])

        # Compute centroids
        det_centroids = [
            ((b[0] + b[2]) / 2.0, (b[1] + b[3]) / 2.0)
            for b in person_bboxes
        ]

        # ── 2. Match detections to existing tracks ──────────────────
        matches, unmatched_dets = match_detections_to_tracks(
            det_centroids, tracked, MATCH_DISTANCE_PX
        )

        # Update matched tracks
        for tp, det_idx in matches:
            bbox = person_bboxes[det_idx]
            centroid = det_centroids[det_idx]

            tp.last_centroid = tp.centroid
            tp.centroid = centroid
            tp.bbox = bbox
            tp.missing_frames = 0

            # ── Anchor-point stillness tracking ─────────────────────
            if tp.state != STATE_COOLDOWN:
                current_time = frame_ts

                if tp.anchor_centroid is None:
                    # No anchor set yet — compute movement from last centroid
                    movement = np.hypot(
                        centroid[0] - tp.last_centroid[0],
                        centroid[1] - tp.last_centroid[1]
                    )
                    if movement <= MOVEMENT_EPSILON_PX:
                        # First stillness observed — set anchor
                        tp.anchor_centroid = centroid
                        tp.anchor_set_time = current_time
                        tp.stillness_duration = 0.0
                        tp.movement_reset_counter = 0
                else:
                    # Anchor exists — compare current centroid to anchor
                    dist_from_anchor = np.hypot(
                        centroid[0] - tp.anchor_centroid[0],
                        centroid[1] - tp.anchor_centroid[1]
                    )

                    if dist_from_anchor <= MOVEMENT_EPSILON_PX:
                        # Still close to anchor — accumulate stillness
                        tp.stillness_duration = current_time - tp.anchor_set_time
                        tp.movement_reset_counter = 0
                    else:
                        # Deviated from anchor — count consecutive bad frames
                        tp.movement_reset_counter += 1
                        if tp.movement_reset_counter >= MOVEMENT_RESET_CONFIRM_FRAMES:
                            # Sustained deviation: reset the anchor
                            prev_stillness = tp.stillness_duration
                            tp.anchor_centroid = centroid
                            tp.anchor_set_time = current_time
                            tp.stillness_duration = 0.0
                            tp.movement_reset_counter = 0
                            # Log the reset
                            if tp.state == STATE_STILL_CANDIDATE:
                                tp.state = STATE_NORMAL
                                tp.posture_bad_frames = 0
                                print(f"  [RESET] pid={tp.person_id}: "
                                      f"STILL_CANDIDATE→NORMAL (anchor reset, "
                                      f"dist={dist_from_anchor:.1f}px, "
                                      f"prev_stillness={prev_stillness:.1f}s)")
                            else:
                                print(f"  [RESET] pid={tp.person_id}: "
                                      f"anchor reset (NORMAL, "
                                      f"dist={dist_from_anchor:.1f}px, "
                                      f"prev_stillness={prev_stillness:.1f}s)")
            else:
                # Cooldown: reset anchor so it's fresh next time
                tp.anchor_centroid = None
                tp.anchor_set_time = 0.0
                tp.movement_reset_counter = 0

        # ── Attempt re-acquisition for unmatched detections ──────────
        still_unmatched = set()
        for det_idx in unmatched_dets:
            bbox = person_bboxes[det_idx]
            centroid = det_centroids[det_idx]
            reacquired = False

            # Check against recently-lost tracks
            expired_keys = []
            for lost_pid, (
                lc, ldur, lanchor, lanchor_time, lreset_cnt, lost_time,
                lstate, lposture_bad
            ) in list(recently_lost_tracks.items()):
                # Expire old entries
                if frame_ts - lost_time > LOST_TRACK_EXPIRY_SEC:
                    expired_keys.append(lost_pid)
                    continue
                # Check distance
                dist = np.hypot(centroid[0] - lc[0], centroid[1] - lc[1])
                if dist <= REACQUIRE_DISTANCE_PX:
                    # Re-acquire!
                    print(f"  [TRACK] Re-acquired person_id={lost_pid} at frame {frame_idx} "
                          f"(dist={dist:.1f}px, restored stillness={ldur:.1f}s, "
                          f"state={lstate})")
                    tp = TrackedPerson(lost_pid, bbox, centroid)
                    # Restore accumulated stillness and state
                    tp.stillness_duration = ldur
                    tp.state = lstate
                    tp.posture_bad_frames = lposture_bad
                    # Back-date anchor_set_time so stillness accumulates from saved value
                    tp.anchor_centroid = centroid
                    tp.anchor_set_time = frame_ts - ldur if ldur > 0 else frame_ts
                    tp.movement_reset_counter = lreset_cnt
                    tracked[lost_pid] = tp
                    reacquired = True
                    expired_keys.append(lost_pid)
                    break

            for ek in expired_keys:
                del recently_lost_tracks[ek]

            if not reacquired:
                still_unmatched.add(det_idx)

        # Create new tracks for truly unmatched detections
        for det_idx in still_unmatched:
            bbox = person_bboxes[det_idx]
            centroid = det_centroids[det_idx]
            pid = new_person_id()
            tracked[pid] = TrackedPerson(pid, bbox, centroid)
            print(f"  [TRACK] New person_id={pid} at frame {frame_idx}")

        # ── Handle missing tracks ─────────────────────────────────────
        to_remove = []
        for pid, tp in list(tracked.items()):
            if pid not in {m[0].person_id for m in matches}:
                tp.missing_frames += 1
                if tp.missing_frames > MAX_MISSING_FRAMES:
                    to_remove.append(pid)

        for pid in to_remove:
            tp = tracked[pid]
            print(f"  [TRACK] Lost person_id={pid} at frame {frame_idx} "
                  f"(stillness={tp.stillness_duration:.1f}s)")
            # Save to recently-lost buffer before deletion
            recently_lost_tracks[pid] = (
                tp.centroid,
                tp.stillness_duration,
                tp.anchor_centroid,
                tp.anchor_set_time,
                tp.movement_reset_counter,
                frame_ts,
                tp.state,
                tp.posture_bad_frames,
            )
            del tracked[pid]

        # ── 3. Run pose estimation on STILL_CANDIDATE persons ────────
        # Collect persons that need pose estimation
        pose_candidates = [
            tp for tp in tracked.values()
            if tp.state in (STATE_STILL_CANDIDATE, STATE_POSTURE_CONFIRMED)
        ]
        if pose_candidates:
            pose_bboxes = [tp.bbox for tp in pose_candidates]
            pose_results = run_pose_on_persons(pose_model, frame, pose_bboxes)
            for tp, (kps, scores) in zip(pose_candidates, pose_results):
                if kps is not None and scores is not None:
                    tp.keypoints = kps
                    head_ang, torso_ang = compute_posture_angles(kps, scores)
                    if head_ang is not None:
                        tp.head_angle = head_ang
                        tp.torso_angle = torso_ang
                else:
                    # Pose failed — reset posture counters to be safe
                    tp.posture_bad_frames = max(0, tp.posture_bad_frames - 1)

        # ── 4. State-machine updates ─────────────────────────────────
        for tp in tracked.values():
            update_state(tp, fps_video)

        # ── 4b. Stillness milestone tracking ──────────────────────────
        for tp in tracked.values():
            if tp.anchor_centroid is not None and tp.stillness_duration > 0:
                pid_ms = _stillness_milestones.setdefault(tp.person_id, set())
                pct = int((tp.stillness_duration / STILLNESS_THRESHOLD_SEC) * 100)
                for milestone in [10, 25, 50, 75, 90, 100]:
                    if pct >= milestone and milestone not in pid_ms:
                        pid_ms.add(milestone)
                        print(f"  [MILESTONE] pid={tp.person_id} "
                              f"stillness={tp.stillness_duration:.1f}s "
                              f"({milestone}% of {STILLNESS_THRESHOLD_SEC}s) "
                              f"state={tp.state} "
                              f"anchor_set_time={tp.anchor_set_time:.1f}s")

        # ── 4c. Debug: anchor-point stillness info every 30 frames ───
        if frame_idx % 30 == 0:
            for tp in tracked.values():
                if tp.anchor_centroid is not None:
                    dist = np.hypot(
                        tp.centroid[0] - tp.anchor_centroid[0],
                        tp.centroid[1] - tp.anchor_centroid[1]
                    )
                    pct = (tp.stillness_duration / STILLNESS_THRESHOLD_SEC) * 100
                    print(f"  [DEBUG] pid={tp.person_id} state={tp.state} "
                          f"anchor=({tp.anchor_centroid[0]:.0f},{tp.anchor_centroid[1]:.0f}) "
                          f"cur=({tp.centroid[0]:.0f},{tp.centroid[1]:.0f}) "
                          f"dist={dist:.1f}px "
                          f"still={tp.stillness_duration:.1f}s/{STILLNESS_THRESHOLD_SEC}s "
                          f"({pct:.0f}%) "
                          f"rst_cnt={tp.movement_reset_counter}")

        # ── 5. Draw overlays ─────────────────────────────────────────
        for tp in tracked.values():
            draw_overlay(frame, tp)

        # ── 6. Global overlays ───────────────────────────────────────
        elapsed_total = time.time() - tick_start
        proc_fps = frame_idx / elapsed_total if elapsed_total > 0 else 0
        cv2.putText(
            frame, f"Frame: {frame_idx}/{total_frames}  FPS: {proc_fps:.1f}",
            (10, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 0, 255), 2
        )

        # Person count per state
        state_counts = defaultdict(int)
        for tp in tracked.values():
            state_counts[tp.state] += 1
        status_y = 65
        for state in [STATE_NORMAL, STATE_STILL_CANDIDATE,
                       STATE_POSTURE_CONFIRMED, STATE_COOLDOWN]:
            cnt = state_counts[state]
            if cnt > 0:
                col = STATE_COLORS.get(state, (255, 255, 255))
                cv2.putText(frame, f"{state}: {cnt}", (10, status_y),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.55, col, 2)
                status_y += 25

        # ── 7. Write output frame ────────────────────────────────────
        out_writer.write(frame)

        if SHOW_DISPLAY:
            cv2.imshow("Sleep Detection", frame)
            if cv2.waitKey(1) & 0xFF == ord("q"):
                print("[INFO] User pressed 'q' — stopping.")
                break

        # ── 8. Console progress ──────────────────────────────────────
        if frame_idx % 100 == 0 or frame_idx == 1:
            n_persons = len(tracked)
            still_candidates = state_counts[STATE_STILL_CANDIDATE]
            confirmed = state_counts[STATE_POSTURE_CONFIRMED]
            print(f"  [PROGRESS] frame={frame_idx}/{total_frames}  "
                  f"persons_tracked={n_persons}  "
                  f"still_candidates={still_candidates}  "
                  f"confirmed={confirmed}  "
                  f"fps={proc_fps:.1f}")

    # ── Cleanup ─────────────────────────────────────────────────────────
    cap.release()
    out_writer.release()
    if SHOW_DISPLAY:
        cv2.destroyAllWindows()

    total_time = time.time() - tick_start
    print(f"\n[INFO] Done.  Processed {frame_idx} frames in {total_time:.1f}s "
          f"({frame_idx / total_time:.1f} avg FPS)")
    print(f"[INFO] Annotated video saved → {OUTPUT_VIDEO}")
    print(f"[INFO] Event log saved → {LOG_FILE}")


# ═══════════════════════════════════════════════════════════════════════════
if __name__ == "__main__":
    main()
