#  Person tracker  (simple centroid-distance matching, no Kalman / DeepSORT)
# ═══════════════════════════════════════════════════════════════════════════

_next_person_id = 0      # global auto-increment

def new_person_id():
    global _next_person_id
    pid = _next_person_id
    _next_person_id += 1
    return pid


class TrackedPerson:
    """Per-person state that persists across frames."""
    __slots__ = (
        "person_id", "bbox", "centroid", "last_centroid",
        "stillness_duration", "state", "posture_bad_frames",
        "cooldown_remaining", "missing_frames", "keypoints",
        "head_angle", "torso_angle",
        "anchor_centroid", "anchor_set_time", "movement_reset_counter",
    )

    def __init__(self, person_id: int, bbox, centroid):
        self.person_id = person_id
        self.bbox = bbox                # (x1, y1, x2, y2) ints
        self.centroid = centroid        # (cx, cy) float
        self.last_centroid = centroid   # previous-frame centroid (kept for legacy)
        self.stillness_duration = 0.0   # accumulated seconds of stillness
        self.state = STATE_NORMAL
        self.posture_bad_frames = 0     # consecutive frames with bad posture
        self.cooldown_remaining = 0.0   # seconds left in cooldown
        self.missing_frames = 0         # frames since last matched
        self.keypoints = None           # latest (17,2) array or None
        self.head_angle = 0.0
        self.torso_angle = 0.0
        # ── Anchor-point stillness fields ───────────────────────────
        self.anchor_centroid = None     # (cx, cy) set when first stillness observed
        self.anchor_set_time = 0.0      # timestamp when anchor was set
        self.movement_reset_counter = 0 # consecutive frames above epsilon before reset


def match_detections_to_tracks(det_centroids, tracked, match_dist):
    """Greedy nearest-neighbour matching.

    Returns:
        matches:  list of (tracked_person, det_idx) tuples
        unmatched_dets:  set of detection indices not matched
    """
    if not tracked or not det_centroids:
        return [], set(range(len(det_centroids)))

    # Build distance matrix
    track_list = list(tracked.values())
    used_dets = set()
    matches = []

    # For each tracked person, find the closest unmatched detection
    for t in track_list:
        best_idx = None
        best_dist = float("inf")
        for i, dc in enumerate(det_centroids):
            if i in used_dets:
                continue
            d = np.hypot(t.centroid[0] - dc[0], t.centroid[1] - dc[1])
            if d < best_dist and d < match_dist:
                best_dist = d
                best_idx = i
        if best_idx is not None:
            matches.append((t, best_idx))
            used_dets.add(best_idx)

    unmatched_dets = set(range(len(det_centroids))) - used_dets
    return matches, unmatched_dets


